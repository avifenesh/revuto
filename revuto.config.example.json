{
  "vaultPath": "~/revuto",
  "github": { "tokenEnv": "GH_TOKEN" },
  "models": {
    "review":   { "name": "local", "baseURL": "http://localhost:8080/v1", "model": "qwen3.6-27b",       "apiKeyEnv": "LOCAL_API_KEY" },
    "curator":  { "name": "local", "baseURL": "http://localhost:8080/v1", "model": "qwen3.6-27b",       "apiKeyEnv": "LOCAL_API_KEY" },
    "distill":  { "name": "local", "baseURL": "http://localhost:8080/v1", "model": "qwen3.6-27b",       "apiKeyEnv": "LOCAL_API_KEY" },
    "embedder": { "name": "local", "baseURL": "http://localhost:8081/v1", "model": "bge-small-en-v1.5", "apiKeyEnv": "LOCAL_API_KEY" }
  },
  "schedules": { "review": "*/12 * * * *", "learn": "0 */4 * * *", "decay": "0 3 * * *" },
  "review": { "maxSteps": 150, "allowWrite": false },
  "limits": {
    "maxOutputTokens": { "review": 32768, "curator": 16384, "distill": 8192 },
    "dailyReviews": 0,
    "learnBatch": 0,
    "dailyLearn": 0,
    "dailyTokens": 0
  },
  "store": { "backend": "surreal", "surreal": { "url": "http://127.0.0.1:8000/rpc", "namespace": "reviewer", "username": "root", "password": "root" } }
}
