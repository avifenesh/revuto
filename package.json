{
  "name": "revuto",
  "version": "0.1.0",
  "type": "module",
  "description": "Local, supplier-agnostic, repo-agnostic autonomous PR reviewer. Stands up a learning reviewer for any repo: clone + onboard + PR-history backfill → curated skill, then poll-review + learn loop with skills graduated into an external (Obsidian) vault.",
  "license": "MIT",
  "author": "Avi Fenesh",
  "keywords": [
    "pr-review",
    "code-review",
    "ai",
    "agent",
    "llm",
    "openai-compatible",
    "obsidian",
    "surrealdb",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avifenesh/revuto.git"
  },
  "homepage": "https://github.com/avifenesh/revuto#readme",
  "bugs": {
    "url": "https://github.com/avifenesh/revuto/issues"
  },
  "bin": {
    "revuto": "dist/daemon/src/cli.js"
  },
  "files": [
    "dist",
    "agent-knowledge/skill-writing-best-practices.md",
    "dashboard/package.json",
    "dashboard/package-lock.json",
    "dashboard/svelte.config.js",
    "dashboard/tsconfig.json",
    "dashboard/vite.config.ts",
    "dashboard/src",
    "dashboard/static",
    "dashboard/build",
    "scripts/surreal-start.sh",
    "scripts/llama-server.sh",
    "scripts/revuto-dashboard-serve.sh",
    "scripts/revuto-dashboard-open.sh",
    "scripts/install-revuto-dashboard-desktop.sh",
    "scripts/revuto-guard.sh",
    "deploy",
    "revuto.config.example.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx daemon/src/cli.ts",
    "dashboard:dev": "npm --prefix dashboard run dev --",
    "dashboard:build": "npm --prefix dashboard run build",
    "dashboard:check": "npm --prefix dashboard run check",
    "dashboard:serve": "scripts/revuto-dashboard-serve.sh",
    "dashboard:open": "scripts/revuto-dashboard-open.sh",
    "dashboard:install-desktop": "scripts/install-revuto-dashboard-desktop.sh",
    "start": "node --enable-source-maps dist/daemon/src/cli.js",
    "prepack": "npm run build && npm run dashboard:build"
  },
  "dependencies": {
    "@agent-sh/harness-core": "^0.2.0",
    "@agent-sh/harness-tools": "0.2.0",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@aws-sdk/credential-provider-node": "^3.972.50",
    "@octokit/rest": "^22.0.1",
    "@smithy/hash-node": "^4.3.6",
    "@smithy/protocol-http": "^5.4.6",
    "@smithy/signature-v4": "^5.4.6",
    "ai": "^6.0.188",
    "better-sqlite3": "^12.10.0",
    "gray-matter": "^4.0.3",
    "node-cron": "^4.2.1",
    "surrealdb": "^2.0.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
